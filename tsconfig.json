{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "types": ["vite/client"]
  },
  "include": ["src", "vite-env.d.ts", "src/types/**/*.d.ts"]
}
